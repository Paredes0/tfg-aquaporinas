            "post_job_actions": {},
            "tool_id": "toolshed.g2.bx.psu.edu/repos/bgruening/text_processing/tp_awk_tool/9.5+galaxy3",
            "tool_shed_repository": {
                "changeset_revision": "ab83aa685821",
                "name": "text_processing",
                "owner": "bgruening",
                "tool_shed": "toolshed.g2.bx.psu.edu"
            },
            "tool_state": "{\"code\": \"BEGIN {OFS=\\\"\\\\t\\\"}\\n{\\n    # 1. Detectar si la linea tiene el formato \\\"chr:start-end\\\" en la columna 1\\n    if ($1 ~ /:[0-9]+-[0-9]+/) {\\n        \\n        # Guardamos el nombre original completo temporalmente\\n        full_name = $1;\\n        \\n        # Separamos por los dos puntos \\\":\\\"\\n        split(full_name, parts, \\\":\\\");\\n        chrom_clean = parts[1];    # Aqu\\u00ed guardamos \\\"chr_7D\\\" limpio\\n        \\n        # Separamos la parte de los numeros por el guion \\\"-\\\"\\n        split(parts[2], range, \\\"-\\\");\\n        offset = range[1];         # Aqu\\u00ed guardamos el 12801671\\n        \\n        # 2. Corregir coordenadas (Sumamos el offset a la posici\\u00f3n local)\\n        # Restamos 1 porque si el corte empieza en 100, la base 1 local es la 100 global.\\n        new_start = $4 + offset - 1; \\n        new_end = $5 + offset - 1;\\n        \\n        # 3. Imprimir la l\\u00ednea reconstruida\\n        # Usamos chrom_clean (col 1 limpia) y las nuevas coordenadas\\n        print chrom_clean, $2, $3, new_start, new_end, $6, $7, $8, $9;\\n    }\\n    else {\\n        # Si es una l\\u00ednea de encabezado (##) o no tiene ese formato, imprimir tal cual\\n        print $0;\\n    }\\n}\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": 0, \"__rerun_remap_job_id__\": null}",
            "tool_uuid": null,
            "tool_version": "9.5+galaxy3",
            "type": "tool",

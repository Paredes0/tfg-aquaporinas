            "tool_state": "{\"code\": \"BEGIN {\\n    OFS = \\\"\\\\t\\\";\\n}\\n\\n{\\n    # 1. Limpieza\\n    gsub(/\\\\r/, \\\"\\\", $0);\\n\\n    # 2. Definici\\u00f3n de Variables (CAMBIO IMPORTANTE)\\n    # Usamos la columna 5 (Score) como criterio\\n    # El ClusterID ahora est\\u00e1 en la columna 7\\n    curr_score = $5 + 0;\\n    cluster_id = $7 + 0;\\n\\n    # 3. L\\u00f3gica de selecci\\u00f3n (EL DE MAYOR SCORE)\\n    if (curr_score > max_score[cluster_id]) {\\n        max_score[cluster_id] = curr_score;\\n\\n        # Guardamos la l\\u00ednea ganadora (6 columnas est\\u00e1ndar)\\n        clean_line = $1 \\\"\\\\t\\\" $2 \\\"\\\\t\\\" $3 \\\"\\\\t\\\" $4 \\\"\\\\t\\\" $5 \\\"\\\\t\\\" $6;\\n\\n        best_line[cluster_id] = clean_line;\\n    }\\n}\\n\\nEND {\\n    for (id in best_line) {\\n        print best_line[id];\\n    }\\n}\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": 0, \"__rerun_remap_job_id__\": null}",

                }
            },
            "tool_id": "toolshed.g2.bx.psu.edu/repos/bgruening/text_processing/tp_awk_tool/9.5+galaxy3",
            "tool_shed_repository": {
                "changeset_revision": "ab83aa685821",
                "name": "text_processing",
                "owner": "bgruening",
                "tool_shed": "toolshed.g2.bx.psu.edu"
            },
            "tool_state": "{\"code\": \"BEGIN { OFS=\\\"\\\\t\\\" }\\n\\n# 1. BLOQUE GENE: Capturar el Score\\n# Se ejecuta solo si la tercera columna es 'gene'\\n$3 == \\\"gene\\\" {\\n    # Extraemos el ID del gen (ej: ID=gene123)\\n    match($9, /ID=([^;]+)/, arr_id);\\n    gene_id = arr_id[1];\\n    \\n    # Guardamos el score (Columna 6) asociado a ese ID\\n    # scores[gene123] = 4500\\n    scores[gene_id] = $6;\\n}\\n\\n# 2. BLOQUE mRNA: Procesar y asignar Score\\n# Se ejecuta solo si la tercera columna es 'mRNA'\\n$3 == \\\"mRNA\\\" {\\n    # --- A. L\\u00f3gica de Coordenadas (ORIGINAL DE TU WORKFLOW) ---\\n    split($1, coords, \\\":\\\");\\n    cromosoma = coords[1];\\n    split(coords[2], rango, \\\"-\\\");\\n    offset = rango[1];\\n    \\n    # Ajuste de coordenadas relativas a absolutas\\n    inicio = offset + $4 - 1; # Restamos 1 para formato BED (base-0) si es necesario, o lo dejamos como estaba si usas GFF\\n    fin = offset + $5;\\n\\n    # --- B. Limpieza del ID (ORIGINAL) ---\\n    match($9, /ID=([^;]+)/, arr_id);\\n    id_mrna = arr_id[1];\\n    gsub(/[[:space:]]/, \\\"\\\", id_mrna);\\n\\n    # --- C. Recuperaci\\u00f3n del Score (NUEVA L\\u00d3GICA) ---\\n    # Buscamos qui\\u00e9n es el padre de este mRNA\\n    match($9, /Parent=([^;]+)/, arr_parent);\\n    parent_id = arr_parent[1];\\n    \\n    # Recuperamos el score del padre desde el array guardado arriba\\n    final_score = (parent_id in scores) ? scores[parent_id] : 0;\\n\\n    # --- D. Salida ---\\n    # Col 1-3: Coordenadas\\n    # Col 4: ID del mRNA\\n    # Col 5: Score REAL (Recuperado del gen)\\n    # Col 6: Strand (Columna 7 original del GFF)\\n    print cromosoma, inicio, fin, id_mrna, final_score, $7\\n}\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": 0, \"__rerun_remap_job_id__\": null}",
            "tool_uuid": null,
